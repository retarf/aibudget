#!/usr/bin/env python3
"""Executable entry point for the aibudget developer CLI.

Run from the project root, e.g.:

    ./cli openspec init
"""
import os
import sys

# Ensure the project root (this file's directory) is importable so that
# `aibudget_cli.main` resolves regardless of the current working directory.
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from aibudget_cli.main import cli

if __name__ == "__main__":
    cli()
