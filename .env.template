# .env.template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.template .env
#
# The `.env` file is created, edited, and deleted MANUALLY by the developer.
# It holds all credentials and is never committed to version control.
# This template lists every variable the project needs, with example values.

# --- PostgreSQL (shared credentials) ---
# The backend is split into per-domain services, each with its own database
# (budget / category / transaction). They all share these credentials; the
# database names and hosts are wired up in docker-compose.yml, so only the
# user and password live here.
POSTGRES_USER=aibudget
POSTGRES_PASSWORD=change-me

# --- API gateway (FastAPI) ---
# Host port the gateway is published on (container always listens on 8000).
BACKEND_PORT=8000
# Comma-separated browser origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:5173

# --- Frontend (React + Vite) ---
FRONTEND_PORT=5173
# Base URL the browser uses to reach the REST API (the gateway).
VITE_API_URL=http://localhost:8000

# --- NATS (inter-service messaging) ---
# Used by the gateway and services. docker-compose.yml sets this per container
# to nats://nats:4222; override here only when running a service outside
# Compose.
NATS_URL=nats://nats:4222
