# .env.template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.template .env
#
# The `.env` file is created, edited, and deleted MANUALLY by the developer.
# It holds all credentials and is never committed to version control.
# This template lists every variable the project needs, with example values.

# --- PostgreSQL database ---
POSTGRES_USER=aibudget
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aibudget
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Backend (FastAPI) ---
# SQLAlchemy connection URL; host/credentials must match the PostgreSQL block.
DATABASE_URL=postgresql+psycopg://aibudget:change-me@db:5432/aibudget
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated browser origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:5173

# --- Frontend (React + Vite) ---
FRONTEND_PORT=5173
# Base URL the browser uses to reach the REST API.
VITE_API_URL=http://localhost:8000

# --- NATS (microservices) ---
NATS_URL=nats://nats:4222
